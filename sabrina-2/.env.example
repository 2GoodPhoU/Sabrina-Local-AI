# Sabrina AI - environment variables.
# Copy this file to .env and fill in values. .env is gitignored.

# Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional overrides (uncomment to use). Format: SABRINA_<SECTION>__<KEY>
# SABRINA_BRAIN__DEFAULT=ollama
# SABRINA_BRAIN__CLAUDE__MODEL=claude-haiku-4-5-20251001
# SABRINA_LOGGING__LEVEL=DEBUG
